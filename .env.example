# ═══════════════════════════════════════════════
# Community Hero - Environment Variables Example
# ═══════════════════════════════════════════════
# Copy this file as .env and fill in the values

# ─── Server ───────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://username:password@localhost:5432/community_hero

# ─── JWT ──────────────────────────────────────
# Generate strong secrets for production:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ─── OpenAI ──────────────────────────────────
# Required for AI features (image analysis, categorization, chat)
# Get your API key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4.1

# ─── Cloudinary ──────────────────────────────
# Required for cloud image storage
# Get credentials at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Google OAuth ────────────────────────────
# Required for Google Sign-In
# Set up at: https://console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Email (SMTP) ───────────────────────────
# Required for email notifications and OTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@communityhero.app

# ─── Frontend ───────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Rate Limiting ──────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
