// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────

enum Role {
  CITIZEN
  OFFICER
  ADMIN
}

enum ComplaintStatus {
  DRAFT
  SUBMITTED
  PENDING_REVIEW
  ACCEPTED
  ASSIGNED
  IN_PROGRESS
  WORK_STARTED
  AWAITING_VERIFICATION
  RESOLVED
  CLOSED
  REJECTED
}

enum ComplaintCategory {
  POTHOLE
  GARBAGE
  WATER_LEAKAGE
  BROKEN_STREETLIGHT
  SEWAGE_PROBLEM
  ROAD_DAMAGE
  ILLEGAL_DUMPING
  TRAFFIC_SIGNAL_FAILURE
  FALLEN_TREE
  PUBLIC_PROPERTY_DAMAGE
  OTHER
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VoteType {
  VERIFY
  REJECT
  FLAG
}

enum ImageType {
  REPORT
  BEFORE
  AFTER
  EVIDENCE
}

enum NotificationType {
  STATUS_CHANGE
  NEARBY_COMPLAINT
  VERIFICATION_REQUEST
  BADGE_EARNED
  LEVEL_UP
  CHALLENGE_COMPLETE
  COMMENT
  ASSIGNMENT
  SYSTEM
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
}

enum AchievementType {
  REPORTS_SUBMITTED
  REPORTS_VERIFIED
  REPORTS_RESOLVED
  COMMENTS_MADE
  VOTES_CAST
  STREAK_DAYS
  POINTS_EARNED
  LEVEL_REACHED
  BADGES_EARNED
}

// ─── Models ──────────────────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  password       String?
  name           String
  phone          String?   @unique
  avatar         String?
  role           Role      @default(CITIZEN)
  points         Int       @default(0)
  xp             Int       @default(0)
  level          Int       @default(1)
  streak         Int       @default(0)
  lastActiveDate DateTime?
  googleId       String?   @unique
  isVerified     Boolean   @default(false)
  isActive       Boolean   @default(true)
  bio            String?
  address        String?
  ward           String?
  latitude       Float?
  longitude      Float?
  otpCode        String?
  otpExpiresAt   DateTime?
  refreshToken   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  complaints         Complaint[]         @relation("ReporterComplaints")
  assignedComplaints Complaint[]         @relation("OfficerComplaints")
  comments           Comment[]
  votes              Vote[]
  notifications      Notification[]
  badges             UserBadge[]
  statusChanges      StatusHistory[]
  chatMessages       ChatMessage[]
  auditLogs          AuditLog[]
  challengeProgress  ChallengeProgress[]
  department         Department?         @relation(fields: [departmentId], references: [id])
  departmentId       String?

  @@index([email])
  @@index([role])
  @@index([points])
  @@index([latitude, longitude])
}

model Complaint {
  id          String            @id @default(uuid())
  title       String
  description String
  category    ComplaintCategory
  severity    Severity          @default(MEDIUM)
  priority    Priority          @default(MEDIUM)
  status      ComplaintStatus   @default(SUBMITTED)

  // Location
  latitude  Float
  longitude Float
  address   String
  ward      String?
  landmark  String?

  // AI Fields
  aiConfidence  Float?
  aiTags        String[]
  estimatedCost Float?
  estimatedTime String?
  aiDescription String?

  // Verification
  verificationCount Int   @default(0)
  rejectionCount    Int   @default(0)
  flagCount         Int   @default(0)
  communityScore    Float @default(0)

  // Duplicate tracking
  duplicateOfId String?
  duplicateOf   Complaint?  @relation("DuplicateComplaints", fields: [duplicateOfId], references: [id])
  duplicates    Complaint[] @relation("DuplicateComplaints")

  // Relations
  reporter          User        @relation("ReporterComplaints", fields: [reporterId], references: [id])
  reporterId        String
  assignedOfficer   User?       @relation("OfficerComplaints", fields: [assignedOfficerId], references: [id])
  assignedOfficerId String?
  department        Department? @relation(fields: [departmentId], references: [id])
  departmentId      String?

  images        ComplaintImage[]
  comments      Comment[]
  votes         Vote[]
  statusHistory StatusHistory[]
  notifications Notification[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?

  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([latitude, longitude])
  @@index([reporterId])
  @@index([assignedOfficerId])
  @@index([departmentId])
  @@index([createdAt])
  @@index([ward])
}

model ComplaintImage {
  id          String    @id @default(uuid())
  url         String
  publicId    String?
  type        ImageType @default(REPORT)
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  complaintId String
  uploadedAt  DateTime  @default(now())

  @@index([complaintId])
}

model Comment {
  id          String    @id @default(uuid())
  content     String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  complaintId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([complaintId])
  @@index([userId])
}

model Vote {
  id          String    @id @default(uuid())
  type        VoteType
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  complaint   Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  complaintId String
  createdAt   DateTime  @default(now())

  @@unique([userId, complaintId])
  @@index([complaintId])
}

model StatusHistory {
  id          String           @id @default(uuid())
  fromStatus  ComplaintStatus?
  toStatus    ComplaintStatus
  note        String?
  changedBy   User             @relation(fields: [changedById], references: [id])
  changedById String
  complaint   Complaint        @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  complaintId String
  createdAt   DateTime         @default(now())

  @@index([complaintId])
}

model Notification {
  id          String           @id @default(uuid())
  title       String
  message     String
  type        NotificationType
  read        Boolean          @default(false)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  complaint   Complaint?       @relation(fields: [complaintId], references: [id], onDelete: SetNull)
  complaintId String?
  data        Json?
  createdAt   DateTime         @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model Department {
  id           String      @id @default(uuid())
  name         String      @unique
  description  String?
  contactEmail String?
  contactPhone String?
  icon         String?
  color        String?
  isActive     Boolean     @default(true)
  complaints   Complaint[]
  officers     User[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Badge {
  id             String      @id @default(uuid())
  name           String      @unique
  description    String
  icon           String
  color          String      @default("#6366f1")
  criteria       String
  pointsRequired Int         @default(0)
  category       String      @default("general")
  users          UserBadge[]
  createdAt      DateTime    @default(now())
}

model UserBadge {
  id       String   @id @default(uuid())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  badgeId  String
  earnedAt DateTime @default(now())

  @@unique([userId, badgeId])
}

model Achievement {
  id          String          @id @default(uuid())
  name        String          @unique
  description String
  icon        String
  type        AchievementType
  target      Int
  reward      Int             @default(0)
  createdAt   DateTime        @default(now())
}

model Challenge {
  id          String              @id @default(uuid())
  name        String
  description String
  type        ChallengeType
  target      Int
  reward      Int                 @default(0)
  category    String?
  isActive    Boolean             @default(true)
  startDate   DateTime
  endDate     DateTime
  progress    ChallengeProgress[]
  createdAt   DateTime            @default(now())
}

model ChallengeProgress {
  id          String    @id @default(uuid())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  challengeId String
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?

  @@unique([userId, challengeId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  content   String
  role      String // "user" | "assistant"
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  sessionId String
  createdAt DateTime @default(now())

  @@index([userId, sessionId])
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String?
  details   Json?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}
